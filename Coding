<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pizza World</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
        }

        header {
            background: #0d6efd;
            color: white;
            text-align: center;
            padding: 80px 20px;
        }

        nav {
            background: #333;
            padding: 15px;
            text-align: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
        }

        section {
            padding: 60px 20px;
            max-width: 1000px;
            margin: auto;
        }

        .services {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .card {
            background: #f4f4f4;
            padding: 20px;
            border-radius: 10px;
        }

        .cta {
            text-align: center;
            background: #0d6efd;
            color: white;
            padding: 50px 20px;
        }

        .btn {
            display: inline-block;
            background: white;
            color: #0d6efd;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 5px;
            margin-top: 15px;
            font-weight: bold;
        }

        footer {
            text-align: center;
            padding: 20px;
            background: #222;
            color: white;
        }
    </style>
</head>
<body>

<header>
    <h1>Your Business Name</h1>
    <p>Professional Solutions for Your Customers</p>
</header>

<nav>
    <a href="#about">About</a>
    <a href="#services">Services</a>
    <a href="#contact">Contact</a>
</nav>

<section id="about">
    <h2>About Us</h2>
    <p>
        We provide high-quality services and help businesses grow.
        Replace this text with information about your company.
    </p>
</section>

<section id="services">
    <h2>Our Services</h2>

    <div class="services">
        <div class="card">
            <h3>Service 1</h3>
            <p>Description of your service.</p>
        </div>

        <div class="card">
            <h3>Service 2</h3>
            <p>Description of your service.</p>
        </div>

        <div class="card">
            <h3>Service 3</h3>
            <p>Description of your service.</p>
        </div>
    </div>
</section>

<section id="contact">
    <h2>Contact Us</h2>
    <p>Email:pizzaworld.np@gmail.com</p>
    <p>Phone: 014991933</p>
</section>

<div class="cta">
    <h2>Ready to Work With Us?</h2>
    <a href="mailto:info@yourbusiness.com" class="btn">
        Get a Quote
    </a>
</div>

<footer>
    <p>© 2026 Your Business Name. All Rights Reserved.</p>
</footer>

</body>
</html>
